# ============================================================
# HR 피드백 보조 AI - 환경 변수 설정 예시
# 이 파일을 복사해서 .env 로 이름을 바꾼 뒤 값을 채워주세요.
# .env 는 git에 커밋되지 않습니다 (.gitignore 참고)
# ============================================================

# Anthropic API 키 - https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=sk-ant-여기에_실제_API_키를_입력하세요

# 세션 보안 시크릿 - 랜덤 문자열 (예: openssl rand -hex 32)
SESSION_SECRET=여기에_랜덤_시크릿을_입력하세요
